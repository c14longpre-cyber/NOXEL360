{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "jsx": "react-jsx",
    "moduleResolution": "bundler",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,

    "types": ["vite/client"],

    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src", "src/**/*.d.ts"]
}